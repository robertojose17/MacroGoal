{
  "expo": {
    "name": "Newly",
    "slug": "Newly",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/newly.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.robertojose17.macrogoal",
      "buildNumber": "345",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthUpdateUsageDescription": "This app uses HealthKit to write your nutrition and fitness data, helping you track your health goals.",
        "NSHealthShareUsageDescription": "This app uses HealthKit to read your health and fitness data, so you can see your progress and stay on track with your goals."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/newly.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.robertojose17.macrogoal",
      "versionCode": 5
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "natively",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27643cef-052f-491e-ac99-87e9e0a31802"
      }
    }
  }
}